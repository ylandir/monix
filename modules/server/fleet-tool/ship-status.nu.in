#!@NUSHELL@
def esc [name: string] {
  if ($env.NO_COLOR? | default "" | is-not-empty) { "" } else { (ansi $name) }
}
def bytes [b] {
  if ($b | describe) == "nothing" { return "n/a" }
  let s = ($b | into string | str trim)
  if $s == "" or $s == "[not set]" { return "n/a" }
  try { $s | into int | into filesize | into string } catch { "n/a" }
}
def dur [secs] {
  let s = ($secs | into int)
  let d = ($s / 86400 | math floor)
  let h = (($s mod 86400) / 3600 | math floor)
  let m = (($s mod 3600) / 60 | math floor)
  let sec = ($s mod 60)
  if $d > 0 { $"($d)d ($h)h" } else if $h > 0 { $"($h)h ($m)m" } else if $m > 0 { $"($m)m ($sec)s" } else { $"($sec)s" }
}
def svc [u: string] {
  let v = (^systemctl is-active $u | complete | get stdout | str trim)
  if $v == "active" { $"(esc green)● active(esc reset)" } else if $v == "activating" { $"(esc yellow)◐ starting(esc reset)" } else { $"(esc red)● ($v)(esc reset)" }
}
# Print one boxed content line, clamped to the box width (SHIP_BW, set in
# main). Overlong lines are truncated with an ellipsis, measured and cut
# ANSI-free so a sliced escape can't bleed color past the line.
def row [text: string] {
  let w = (($env.SHIP_BW | into int) - 2)
  if (($text | ansi strip | str length) <= $w) {
    print $"│ ($text)"
  } else {
    print $"│ ($text | ansi strip | str substring 0..($w - 2))…"
  }
}
def rule [lc: string, rc: string, title: string, bw: int, style: string] {
  let d = (if ($title | is-empty) { $bw - 2 } else { $bw - 5 - ($title | str length) })
  let d = (if $d < 0 { 0 } else { $d })
  let dash = (0..<$d | each { "─" } | str join)
  let col = (esc $style)
  if ($title | is-empty) {
    print $"($col)($lc)($dash)($rc)(esc reset)"
  } else {
    print $"($col)($lc)─ ($title) ($dash)($rc)(esc reset)"
  }
}
def main [] {
  $env.PATH = $"@PATH@:/run/current-system/sw/bin"
  let cols = (try { term size | get columns } catch { 80 })
  let cols = ($env.SHIP_COLS? | default $cols | into int)
  let cols = (if $cols < 20 { 80 } else { $cols })
  let narrow = ($cols < 74)
  let bw = ([$cols 88] | math min)
  $env.SHIP_BW = ($bw | into string)
  let workers = [@WORKERS@]

  let up = (open /proc/uptime | split row " " | first | into float | into int)
  let load = (open /proc/loadavg | split row " " | first 3 | str join " ")
  let mi = (open /proc/meminfo | lines | parse "{k}:{v}")
  let mt = ($mi | where k == MemTotal | get v.0 | str trim | split row " " | first | into int) * 1024
  let ma = ($mi | where k == MemAvailable | get v.0 | str trim | split row " " | first | into int) * 1024
  let mu = ($mt - $ma)
  let kernel = (^uname -r | str trim)
  let host = (sys host | get hostname)
  let cpu = (open /proc/cpuinfo | lines | where ($it | str starts-with "model name") | first | split row ": " | last | str replace --regex " w/.*" "")
  let threads = (^nproc | str trim)
  let rd = (^df -hP / | lines | last | split row --regex '\s+')
  let root = $"($rd.2) / ($rd.1)  \(($rd.4)\)"
  let failed = (^systemctl --failed --no-legend --no-pager | lines | where ($it | str trim | is-not-empty) | length)
  let gen = (^readlink -f /run/current-system | str trim | str replace "/nix/store/" "")

  rule "╭" "╮" "THE KESTREL // SHIP STATUS" $bw "cyan_bold"
  if $narrow {
    row $"(esc attr_bold)BRIDGE(esc reset) ($host) · up (dur $up)"
    row $"kernel ($kernel) · load ($load)"
    row $"($cpu) · ($threads) threads"
    row $"mem (bytes $mu) / (bytes $mt) · failed ($failed)"
    row $"root ($root)"
    row $"(esc attr_dimmed)gen(esc reset) …($gen | str substring (-24..))"
  } else {
    row $"(esc attr_bold)BRIDGE(esc reset) ($host | fill -w 16) kernel ($kernel | fill -w 12) up ((dur $up) | fill -w 9) load ($load)"
    row $"       silicon ($cpu) · ($threads) threads"
    row $"       memory (bytes $mu) / (bytes $mt)   root ($root)   failed units ($failed)"
    row $"       (esc attr_dimmed)generation(esc reset) ($gen)"
  }

  rule "├" "┤" "REACTOR // RAM BY DOMAIN" $bw "cyan"
  for sl in [cockpit.slice agents.slice inference.slice services.slice] {
    let cur = (^systemctl show $sl -p MemoryCurrent --value | str trim)
    let pk = (^systemctl show $sl -p MemoryPeak --value | str trim)
    if $narrow {
      row $"($sl | str replace ".slice" "" | fill -w 10) (bytes $cur) / (bytes $pk) peak"
    } else {
      row $"($sl | fill -w 18) current ((bytes $cur) | fill -w 9 -a right)   peak ((bytes $pk) | fill -w 9 -a right)"
    }
  }

  rule "├" "┤" "HULL" $bw "cyan"
  # Hottest reading per hwmon chip; sysfs is world-readable.
  let temps = (try {
    ls /sys/class/hwmon/hwmon*/temp*_input | get name | each {|f|
      let chip = (try { open ($f | path dirname | path join name) | str trim } catch { "hwmon" })
      let deg = ((open $f | str trim | into int) / 1000 | math round)
      {chip: $chip, deg: $deg}
    } | group-by --to-table chip | each {|g| $"($g.chip) (($g.items.deg | math max))°C" } | str join "  "
  } catch { "n/a" })
  # First UPS upsd knows about; reads are unprivileged.
  let upsname = (try { ^upsc -l localhost | complete | get stdout | lines | first | str trim } catch { "" })
  let ups = (if ($upsname | is-empty) { "" } else {
    (try { ^upsc $"($upsname)@localhost" | complete | get stdout } catch { "" })
  })
  let upsget = {|k| ($ups | lines | parse "{key}: {val}" | where key == $k | get val.0? | default "") }
  let power = (if ($ups | is-empty) { "(no UPS)" } else {
    let st = (do $upsget "ups.status")
    let state = (if ($st | str contains "OB") { $"(esc red_bold)ON BATTERY(esc reset)" }
      else if ($st | str contains "OL") { $"(esc green)online(esc reset)" } else { $st })
    let charge = (do $upsget "battery.charge")
    let runtime = (try { dur (do $upsget "battery.runtime") } catch { "n/a" })
    $"($state) · charge ($charge)% · runtime ($runtime)"
  })
  if $narrow {
    row $"temps ($temps)"
    row $"power ($power)"
    row $"smart (svc smartd.service)  ups (svc upsmon.service)"
  } else {
    row $"temps   ($temps)"
    row $"power   ($power)   smart (svc smartd.service)  ups (svc upsmon.service)"
  }

  rule "├" "┤" "SYSTEMS" $bw "cyan"
  if $narrow {
    row $"cockpit (svc opencode-web.service)  nginx (svc nginx.service)"
    row $"tunnel (svc opencode-web-tunnel.service)  squid (svc squid.service)"
    row $"inference (svc llama-swap.service)"
    row $"tailscale (svc tailscaled.service)"
  } else {
    row $"cockpit (svc opencode-web.service | fill -w 14) tunnel (svc opencode-web-tunnel.service | fill -w 14) inference (svc llama-swap.service)"
    row $"nginx   (svc nginx.service | fill -w 14) squid  (svc squid.service | fill -w 14) tailscale (svc tailscaled.service)"
  }

  rule "├" "┤" "DRONE BAY" $bw "cyan"
  let active = (try { ^/run/wrappers/bin/sudo -n -u @OPERATOR@ @FLEET_PATH@ active | complete | get stdout } catch { "" })
  let atbl = ($active | lines | where ($it | str trim | is-not-empty) | parse "{w}\t{id}\t{agent}\t{model}\t{age}")
  mut warm = 0
  mut starting = 0
  mut failed_w = 0
  for b in $workers {
    let st = (^systemctl is-active $"microvm@($b).service" | complete | get stdout | str trim)
    let row = ($atbl | where w == $b)
    let marker = (if $st == "active" { $"(esc green)●(esc reset)" } else if $st == "activating" { $"(esc yellow)◐(esc reset)" } else { $"(esc red)●(esc reset)" })
    if $st == "active" { $warm = $warm + 1 } else if $st == "activating" { $starting = $starting + 1 } else { $failed_w = $failed_w + 1 }
    if ($row | length) > 0 {
      let r = ($row | first)
      if $narrow {
        row $"($marker) ($b | fill -w 11) ($r.agent) ($r.model)"
        row $"  (dur $r.age)  ($r.id)"
      } else {
        row $"($marker) ($b | fill -w 11) ($r.agent | fill -w 7) ($r.model | fill -w 24) ((dur $r.age) | fill -w 8 -a right)  ($r.id)"
      }
    } else if $st == "active" {
      row $"($marker) ($b | fill -w 11) (esc attr_dimmed)idle(esc reset)"
    } else {
      row $"($marker) ($b | fill -w 11) ($st)"
    }
  }
  row $"pool (esc attr_bold)($warm)/($workers | length) warm(esc reset)  (esc yellow)($starting) starting(esc reset)  (esc red)($failed_w) failed(esc reset)"
  rule "├" "┤" "LEDGER" $bw "cyan"
  # The wide ledger table needs 85 columns; anything tighter gets the
  # stanza layout rather than a truncated money table.
  let cw = (if ($bw - 2) >= 85 { $bw - 2 } else { 73 } | into string)
  let costs = (with-env { COLUMNS: $cw, NO_COLOR: "1" } { try { ^ship-costs --bare | complete | get stdout } catch { "(ship-costs unavailable)" } })
  for line in ($costs | lines) {
    if ($line | str trim | is-empty) { print "│" } else { row $line }
  }

  rule "├" "┤" "REC DECK" $bw "cyan"
  let tip = (try { ^tailscale ip -4 | lines | first | str trim } catch { "" })
  let mc = (if ($tip | is-not-empty) { try { ^mcstatus $"($tip):25565" status | complete | get stdout } catch { "" } } else { "" })
  let mcget = {|k| ($mc | lines | parse "{key}: {val}" | where key == $k | get val.0? | default "n/a") }
  let players = (do $mcget "players")
  let ver = (do $mcget "version" | str replace --regex ' \(protocol.*' "")
  let ping = (do $mcget "ping")
  let mcmem = (^systemctl show minecraft-server-main.service -p MemoryCurrent --value | str trim)
  if $narrow {
    row $"server (svc minecraft-server-main.service) · players ($players)"
    row $"($ver) · ping ($ping) · (bytes $mcmem)"
  } else {
    row $"server (svc minecraft-server-main.service | fill -w 14) players ($players | fill -w 7) version ($ver | fill -w 14) ping ($ping | fill -w 10) memory (bytes $mcmem)"
  }

  rule "╰" "╯" "" $bw "cyan_bold"
}
